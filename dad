local player = game.Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

-- Colors
local BGColor = Color3.fromRGB(18,18,25)
local AccentColor = Color3.fromRGB(0,255,255)

-- Blur effect
local blur = Instance.new("BlurEffect")
blur.Size = 0
blur.Parent = Lighting
TweenService:Create(blur, TweenInfo.new(0.6), {Size = 12}):Play()

-- ScreenGui
local gui = Instance.new("ScreenGui", playerGui)
gui.Name = "JaradLoadingDark"
gui.IgnoreGuiInset = true
gui.ResetOnSpawn = false

-- Main Frame
local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 460, 0, 180)
frame.Position = UDim2.new(0.5, 0, 0.5, 0)
frame.AnchorPoint = Vector2.new(0.5,0.5)
frame.BackgroundColor3 = BGColor
frame.BackgroundTransparency = 1
frame.BorderSizePixel = 0
Instance.new("UICorner", frame).CornerRadius = UDim.new(0,16)

local stroke = Instance.new("UIStroke", frame)
stroke.Color = AccentColor
stroke.Thickness = 2
stroke.Transparency = 0.6

-- Smooth fade in
TweenService:Create(frame, TweenInfo.new(0.6, Enum.EasingStyle.Back), {BackgroundTransparency = 0.4}):Play()

-- Glow pulse
task.spawn(function()
	while frame.Parent do
		TweenService:Create(stroke, TweenInfo.new(1), {Transparency = 0.2}):Play()
		task.wait(1)
		TweenService:Create(stroke, TweenInfo.new(1), {Transparency = 0.6}):Play()
		task.wait(1)
	end
end)

-- Ultra smooth floating (high-frequency sine wave)
local startPos = frame.Position
local amplitude = 8
local frequency = 4 -- increase frequency for smoother motion
task.spawn(function()
	local t = 0
	while frame.Parent do
		t = t + task.wait()
		local yOffset = math.sin(t * math.pi * 2 * frequency / 10) * amplitude
		frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset, startPos.Y.Scale, startPos.Y.Offset + yOffset)
	end
end)

-- Title
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,-40,0,60)
title.Position = UDim2.new(0,20,0,10)
title.Text = "Jaradz Script"
title.TextColor3 = AccentColor
title.Font = Enum.Font.FredokaOne
title.TextScaled = true
title.BackgroundTransparency = 1

-- Loading text (animated dots)
local loading = Instance.new("TextLabel", frame)
loading.Size = UDim2.new(1,-40,0,40)
loading.Position = UDim2.new(0,20,0.5,-20)
loading.Text = "Loading"
loading.TextColor3 = AccentColor
loading.Font = Enum.Font.FredokaOne
loading.TextScaled = true
loading.BackgroundTransparency = 1

task.spawn(function()
	local dots = 0
	while loading.Parent do
		dots = (dots + 1) % 4
		loading.Text = "Loading" .. string.rep(".", dots)
		task.wait(0.3) -- slightly faster dots for shorter loading
	end
end)

-- Loading Bar BG
local barBg = Instance.new("Frame", frame)
barBg.Size = UDim2.new(1,-40,0,18)
barBg.Position = UDim2.new(0,20,0.7,0)
barBg.BackgroundColor3 = Color3.fromRGB(40,40,60)
barBg.BorderSizePixel = 0
Instance.new("UICorner", barBg).CornerRadius = UDim.new(0,10)

-- Loading Bar Fill
local barFill = Instance.new("Frame", barBg)
barFill.Size = UDim2.new(0,0,1,0)
barFill.BorderSizePixel = 0
Instance.new("UICorner", barFill).CornerRadius = UDim.new(0,10)

-- Gradient effect
local gradient = Instance.new("UIGradient", barFill)
gradient.Color = ColorSequence.new{
	ColorSequenceKeypoint.new(0, AccentColor),
	ColorSequenceKeypoint.new(1, BGColor:Lerp(AccentColor,0.3))
}

-- Animate gradient
task.spawn(function()
	while barFill.Parent do
		TweenService:Create(gradient, TweenInfo.new(1, Enum.EasingStyle.Linear), {Offset = Vector2.new(1,0)}):Play()
		task.wait(1)
		gradient.Offset = Vector2.new(-1,0)
	end
end)

-- Animate bar fill (3.5 seconds)
TweenService:Create(barFill, TweenInfo.new(3.5, Enum.EasingStyle.Quad), {Size = UDim2.new(1,0,1,0)}):Play()

-- Footer (Discord)
local footer = Instance.new("TextLabel", frame)
footer.Size = UDim2.new(1,-40,0,20)
footer.Position = UDim2.new(0,20,1,-30)
footer.Text = "Discord: discord.gg/OMc82nc"
footer.TextColor3 = AccentColor
footer.Font = Enum.Font.Gotham
footer.TextScaled = true
footer.BackgroundTransparency = 1

-- Fade out and destroy (3.5 seconds total)
task.delay(3.5, function()
	for _,v in pairs(frame:GetDescendants()) do
		if v:IsA("TextLabel") then
			TweenService:Create(v, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
		elseif v:IsA("Frame") then
			TweenService:Create(v, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
		end
	end
	TweenService:Create(blur, TweenInfo.new(0.4), {Size = 0}):Play()
	task.wait(0.4)
	gui:Destroy()
	blur:Destroy()
end)

-- Run main script after loading
task.delay(3.6, function()
	loadstring(game:HttpGet("https://raw.githubusercontent.com/TrGhann/dibuhhh/refs/heads/main/kukinlpoh"))()
end)
