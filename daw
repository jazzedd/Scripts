-- Ultra smooth floating (high-frequency sine wave)
local startPos = frame.Position
local amplitude = 8
local frequency = 4 -- increase frequency for smoother motion
task.spawn(function()
	local t = 0
	while frame.Parent do
		t = t + task.wait()
		local yOffset = math.sin(t * math.pi * 2 * frequency / 10) * amplitude
		frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset, startPos.Y.Scale, startPos.Y.Offset + yOffset)
	end
end)

